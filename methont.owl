<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns:dct="http://purl.org/dc/terms/"
   xmlns:owl="http://www.w3.org/2002/07/owl#"
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
   xmlns:skos="http://www.w3.org/2004/02/skos/core#"
>
  <rdf:Description rdf:about="http://independentimpact.org/methodology/uncertaintyType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://independentimpact.org/methodology/UncertaintyModel"/>
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:label xml:lang="en">uncertainty type</rdfs:label>
    <rdfs:comment xml:lang="en">Examples include absolute, relative, confidenceInterval95.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://independentimpact.org/methodology/">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <dct:title xml:lang="en">Methodology ontology (core)</dct:title>
    <dct:description xml:lang="en">Reusable vocabulary for describing methodologies, applicability scopes, constraints, symbols, and ordered equation steps that culminate in an indicator value.</dct:description>
    <dct:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-02-12</dct:issued>
    <dct:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-08</dct:modified>
    <owl:versionIRI rdf:resource="http://independentimpact.org/methont/methont.ttl/1.1.0"/>
    <owl:versionInfo>1.1.0</owl:versionInfo>
    <owl:imports rdf:resource="http://independentimpact.org/indicator-owl/"/>
    <owl:imports rdf:resource="http://w3id.org/aiao"/>
    <owl:imports rdf:resource="http://w3id.org/impactont"/>
    <owl:imports rdf:resource="http://www.w3.org/ns/prov-o"/>
    <owl:imports rdf:resource="http://www.w3.org/ns/shacl"/>
    <owl:imports rdf:resource="http://qudt.org/schema/qudt/"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://independentimpact.org/methodology/hasVariableConstraint">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:nodeID="ne2ab0bcfabb74008a5d9e84debcce3d0b2"/>
    <rdfs:range rdf:resource="http://independentimpact.org/methodology/VariableConstraint"/>
    <rdfs:label xml:lang="en">has variable constraint</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://independentimpact.org/methodology/isRealisedByVariable">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://w3id.org/impactont#Indicator"/>
    <rdfs:range rdf:resource="http://independentimpact.org/methodology/Variable"/>
    <rdfs:label xml:lang="en">is realised by variable</rdfs:label>
    <rdfs:comment xml:lang="en">Inverse relation linking an indicator to variables that operationalize it.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ne2ab0bcfabb74008a5d9e84debcce3d0b3">
    <rdf:first rdf:resource="http://independentimpact.org/methodology/Methodology"/>
    <rdf:rest rdf:nodeID="ne2ab0bcfabb74008a5d9e84debcce3d0b4"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ne2ab0bcfabb74008a5d9e84debcce3d0b19">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:unionOf rdf:nodeID="ne2ab0bcfabb74008a5d9e84debcce3d0b20"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://independentimpact.org/methodology/maxValue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://independentimpact.org/methodology/VariableConstraint"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    <rdfs:label xml:lang="en">maximum value</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://independentimpact.org/methodology/hasScaleClassification">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://independentimpact.org/methodology/Methodology"/>
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:label xml:lang="en">has scale classification</rdfs:label>
    <rdfs:comment xml:lang="en">Direct tag that states whether the methodology is large-scale or small-scale, enabling single-hop filtering without inspecting constraint profiles.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/dc/terms/source">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://independentimpact.org/methodology/Methodology"/>
    <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Resource"/>
    <rdfs:label xml:lang="en">source</rdfs:label>
    <rdfs:comment xml:lang="en">Authoritative source for the methodology definition (e.g., UNFCCC CDM, Gold Standard, Verra).</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://independentimpact.org/methodology/Constant">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Constant</rdfs:label>
    <skos:definition xml:lang="en">A fixed quantity used by a methodology or equation step, e.g., a default GWP value.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ne2ab0bcfabb74008a5d9e84debcce3d0b6">
    <rdf:first rdf:resource="http://independentimpact.org/methodology/Methodology"/>
    <rdf:rest rdf:nodeID="ne2ab0bcfabb74008a5d9e84debcce3d0b7"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://independentimpact.org/methodology/MonitoringFrequency">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://independentimpact.org/methodology/MonitoringRequirement"/>
    <rdfs:label xml:lang="en">monitoring frequency</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://independentimpact.org/methodology/EquationStep">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://independentimpact.org/indicator-owl/IndicatorFormula"/>
    <rdfs:subClassOf rdf:nodeID="ne2ab0bcfabb74008a5d9e84debcce3d0b1"/>
    <rdfs:label xml:lang="en">Equation step</rdfs:label>
    <skos:definition xml:lang="en">An ordered formula that computes one variable using one or more inputs; steps chain together until the indicator is quantified.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://independentimpact.org/methodology/hasMonitoringRequirement">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://independentimpact.org/methodology/Methodology"/>
    <rdfs:range rdf:resource="http://independentimpact.org/methodology/MonitoringRequirement"/>
    <rdfs:label xml:lang="en">has monitoring requirement</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://independentimpact.org/methodology/appliesToSector">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://independentimpact.org/methodology/Methodology"/>
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:label xml:lang="en">applies to sector</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://independentimpact.org/methodology/BaselineState">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://w3id.org/impactont#State"/>
    <rdfs:label xml:lang="en">Baseline state</rdfs:label>
    <skos:definition xml:lang="en">Reference (counterfactual) state representing conditions without the intervention.</skos:definition>
    <owl:disjointWith rdf:resource="http://independentimpact.org/methodology/ProjectState"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://independentimpact.org/methodology/validationShape">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:nodeID="ne2ab0bcfabb74008a5d9e84debcce3d0b5"/>
    <rdfs:range rdf:resource="http://www.w3.org/ns/shacl#NodeShape"/>
    <rdfs:label xml:lang="en">validation shape</rdfs:label>
    <rdfs:comment xml:lang="en">Links a methodology or constraint to the SHACL NodeShape that enforces its rules.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://independentimpact.org/methodology/implementedBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://independentimpact.org/methodology/Methodology"/>
    <rdfs:range rdf:nodeID="ne2ab0bcfabb74008a5d9e84debcce3d0b16"/>
    <rdfs:label xml:lang="en">implemented by</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ne2ab0bcfabb74008a5d9e84debcce3d0b30">
    <rdf:first rdf:resource="http://independentimpact.org/methodology/Methodology"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://independentimpact.org/methodology/activityScope">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://independentimpact.org/methodology/ApplicabilityCondition"/>
    <rdfs:range rdf:resource="http://w3id.org/aiao#Activity"/>
    <rdfs:label xml:lang="en">activity scope</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://independentimpact.org/methodology/computes">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://independentimpact.org/methodology/EquationStep"/>
    <rdfs:range rdf:resource="http://independentimpact.org/methodology/Variable"/>
    <rdfs:label xml:lang="en">computes</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://independentimpact.org/methodology/spatialScope">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://independentimpact.org/methodology/ApplicabilityCondition"/>
    <rdfs:range rdf:resource="http://w3id.org/impactont#SpatialLocation"/>
    <rdfs:label xml:lang="en">spatial scope</rdfs:label>
    <rdfs:comment xml:lang="en">Spatial applicability boundary using impact ontology location semantics.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://independentimpact.org/methodology/dependsOnStep">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://independentimpact.org/methodology/EquationStep"/>
    <rdfs:range rdf:resource="http://independentimpact.org/methodology/EquationStep"/>
    <rdfs:label xml:lang="en">depends on step</rdfs:label>
    <rdfs:comment xml:lang="en">Declares a dependency edge between equation steps for DAG-based execution plans.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://independentimpact.org/methodology/nextStep">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://independentimpact.org/methodology/EquationStep"/>
    <rdfs:range rdf:resource="http://independentimpact.org/methodology/EquationStep"/>
    <rdfs:label xml:lang="en">next step</rdfs:label>
    <rdfs:comment xml:lang="en">Creates an ordered chain of equations; the final step produces the indicator value.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://independentimpact.org/methodology/hasActivityClassification">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://independentimpact.org/methodology/Methodology"/>
    <rdfs:range rdf:nodeID="ne2ab0bcfabb74008a5d9e84debcce3d0b19"/>
    <rdfs:label xml:lang="en">has activity classification</rdfs:label>
    <rdfs:comment xml:lang="en">Direct activity classification tag for methodology filtering; accepts SKOS concepts and activity resources for compatibility.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://independentimpact.org/methodology/usesProjectState">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://independentimpact.org/methodology/Methodology"/>
    <rdfs:range rdf:resource="http://independentimpact.org/methodology/ProjectState"/>
    <rdfs:label xml:lang="en">uses project state</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ne2ab0bcfabb74008a5d9e84debcce3d0b33">
    <rdf:first rdf:resource="http://independentimpact.org/methodology/VariableConstraint"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://independentimpact.org/methodology/DataQualityRequirement">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://independentimpact.org/methodology/MonitoringRequirement"/>
    <rdfs:label xml:lang="en">Data quality requirement</rdfs:label>
    <skos:definition xml:lang="en">A rule defining completeness, calibration, or QA/QC thresholds for accepted data.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://independentimpact.org/methodology/equationStepOf">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://independentimpact.org/methodology/EquationStep"/>
    <rdfs:range rdf:resource="http://independentimpact.org/methodology/Methodology"/>
    <rdfs:label xml:lang="en">equation step of</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://independentimpact.org/methodology/hasApplicability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://independentimpact.org/methodology/Methodology"/>
    <rdfs:range rdf:resource="http://independentimpact.org/methodology/ApplicabilityCondition"/>
    <rdfs:label xml:lang="en">has applicability</rdfs:label>
    <owl:inverseOf rdf:resource="http://independentimpact.org/methodology/applicabilityOf"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://independentimpact.org/methodology/methodCode">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:nodeID="ne2ab0bcfabb74008a5d9e84debcce3d0b22"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label xml:lang="en">method code</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://independentimpact.org/methodology/hasMethodology">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://w3id.org/impactont#Indicator"/>
    <rdfs:range rdf:resource="http://independentimpact.org/methodology/Methodology"/>
    <rdfs:label xml:lang="en">has methodology</rdfs:label>
    <rdfs:comment xml:lang="en">Inverse helper so indicator catalogues can enumerate all compatible methodologies without bespoke queries.</rdfs:comment>
    <owl:inverseOf rdf:resource="http://independentimpact.org/methodology/forIndicator"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://independentimpact.org/methodology/applicabilityOf">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://independentimpact.org/methodology/ApplicabilityCondition"/>
    <rdfs:range rdf:resource="http://independentimpact.org/methodology/Methodology"/>
    <rdfs:label xml:lang="en">applicability of</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://independentimpact.org/methodology/constraintNote">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:nodeID="ne2ab0bcfabb74008a5d9e84debcce3d0b31"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label xml:lang="en">constraint note</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ne2ab0bcfabb74008a5d9e84debcce3d0b17">
    <rdf:first rdf:resource="http://w3id.org/aiao#Agent"/>
    <rdf:rest rdf:nodeID="ne2ab0bcfabb74008a5d9e84debcce3d0b18"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://independentimpact.org/methodology/hasSemanticConstraint">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://independentimpact.org/methodology/Methodology"/>
    <rdfs:range rdf:resource="http://independentimpact.org/methodology/SemanticConstraint"/>
    <rdfs:label xml:lang="en">has semantic constraint</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ne2ab0bcfabb74008a5d9e84debcce3d0b15">
    <rdf:first rdf:resource="http://independentimpact.org/methodology/Constant"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://independentimpact.org/methodology/defaultValue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://independentimpact.org/methodology/Constant"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    <rdfs:label xml:lang="en">default value</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://independentimpact.org/methodology/hasEquationStep">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://independentimpact.org/methodology/Methodology"/>
    <rdfs:range rdf:resource="http://independentimpact.org/methodology/EquationStep"/>
    <rdfs:label xml:lang="en">has equation step</rdfs:label>
    <owl:inverseOf rdf:resource="http://independentimpact.org/methodology/equationStepOf"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://independentimpact.org/methodology/semanticTarget">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://independentimpact.org/methodology/SemanticConstraint"/>
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:label xml:lang="en">semantic target</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://independentimpact.org/methodology/SemanticConstraint">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/shacl#NodeShape"/>
    <rdfs:label xml:lang="en">Semantic constraint</rdfs:label>
    <skos:definition xml:lang="en">Qualitative rule that restricts the applicability of a methodology (e.g., facility classification, compliance status).</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ne2ab0bcfabb74008a5d9e84debcce3d0b25">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:unionOf rdf:nodeID="ne2ab0bcfabb74008a5d9e84debcce3d0b26"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://independentimpact.org/methodology/forIndicator">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://independentimpact.org/methodology/Methodology"/>
    <rdfs:range rdf:resource="http://w3id.org/impactont#Indicator"/>
    <rdfs:label xml:lang="en">for indicator</rdfs:label>
    <rdfs:comment xml:lang="en">Links a methodology to the indicator definition whose value it produces (indicator definition in IndicatorOntology).</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://independentimpact.org/methodology/VariableRole">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Variable role</rdfs:label>
    <skos:definition xml:lang="en">A role assignment that specifies how a variable is used in a particular methodology (e.g., input, output, baseline, project).</skos:definition>
    <rdfs:comment xml:lang="en">Use this class to classify variable function in methodology logic and reporting context; role is attached to the variable, while measured/derived distinction is captured on values.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://independentimpact.org/methodology/validThrough">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:nodeID="ne2ab0bcfabb74008a5d9e84debcce3d0b28"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
    <rdfs:label xml:lang="en">valid through</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://independentimpact.org/methodology/constrainsVariable">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://independentimpact.org/methodology/VariableConstraint"/>
    <rdfs:range rdf:resource="http://independentimpact.org/methodology/Variable"/>
    <rdfs:label xml:lang="en">constrains variable</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://independentimpact.org/methodology/MinimumDataCoverage">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://independentimpact.org/methodology/DataQualityRequirement"/>
    <rdfs:label xml:lang="en">minimum data coverage</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://independentimpact.org/methodology/minValue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://independentimpact.org/methodology/VariableConstraint"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    <rdfs:label xml:lang="en">minimum value</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://independentimpact.org/methodology/temporalScope">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://independentimpact.org/methodology/ApplicabilityCondition"/>
    <rdfs:range rdf:resource="http://w3id.org/impactont#TemporalLocation"/>
    <rdfs:label xml:lang="en">temporal scope</rdfs:label>
    <rdfs:comment xml:lang="en">Temporal applicability boundary using impact ontology time semantics.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://independentimpact.org/methodology/hasVariableRole">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://independentimpact.org/methodology/Variable"/>
    <rdfs:range rdf:resource="http://independentimpact.org/methodology/VariableRole"/>
    <rdfs:label xml:lang="en">has variable role</rdfs:label>
    <rdfs:comment xml:lang="en">Assigns a functional role to a methodology variable (or its symbol representation) within a specific methodology context.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ne2ab0bcfabb74008a5d9e84debcce3d0b14">
    <rdf:first rdf:resource="http://independentimpact.org/methodology/EquationStep"/>
