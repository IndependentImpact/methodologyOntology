    <rdfs:label xml:lang="en">has semantic constraint</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://independentimpact.org/methodology/ValueRole">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Value role</rdfs:label>
    <skos:definition xml:lang="en">Role that a symbol plays within the methodology (measured input or calculated output).</skos:definition>
    <rdfs:comment xml:lang="en">Use this class for methodology symbol roles (e.g., MeasuredInput, DerivedOutput); keep it separate from provenance role vocabularies.</rdfs:comment>
  </rdf:Description>
