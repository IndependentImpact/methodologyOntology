@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix cdmvocab: <http://independentimpact.org/methodology/vocab/cdm/> .
@prefix dct:  <http://purl.org/dc/terms/> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix meth:  <http://independentimpact.org/methodology/> .

<http://independentimpact.org/methodology/vocab/concepts/scale-classifications> a owl:Ontology ;
  dct:title "Methodology scale classifications"@en ;
  dct:description "SKOS concept scheme for methodology activity scales."@en ;
  dct:issued "2026-04-10"^^xsd:date .

meth:ScaleClassificationScheme a skos:ConceptScheme ;
  skos:prefLabel "Methodology scale classifications"@en ;
  skos:definition "Controlled vocabulary of methodology scale types used with meth:hasScaleClassification."@en .









